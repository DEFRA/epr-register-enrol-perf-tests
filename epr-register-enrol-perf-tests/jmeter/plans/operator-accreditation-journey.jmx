<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>

    <!-- ═══════════════════════════════════════════════════════════
         TEST PLAN
         Journey: Operator Accreditation (baseline – 1 user, 1 iteration)
         Entry:   /operator-accreditation/{orgId}/{siteId}/{material}/{year}
         Crawled: localhost:3000  2026-06-17
         ═══════════════════════════════════════════════════════════ -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan"
              testname="Operator Accreditation Journey – Baseline">
      <elementProp name="TestPlan.user_defined_variables"
                   elementType="Arguments" guiclass="ArgumentsPanel">
        <collectionProp name="Arguments.arguments">
          <elementProp name="BASE_URL" elementType="Argument">
            <stringProp name="Argument.name">BASE_URL</stringProp>
            <stringProp name="Argument.value">${__P(base_url,epr-register-enrol-frontend.dev.cdp-int.defra.cloud)}</stringProp>
          </elementProp>
          <elementProp name="USERNAME" elementType="Argument">
            <stringProp name="Argument.name">USERNAME</stringProp>
            <stringProp name="Argument.value">${__P(username,)}</stringProp>
          </elementProp>
          <elementProp name="PASSWORD" elementType="Argument">
            <stringProp name="Argument.name">PASSWORD</stringProp>
            <stringProp name="Argument.value">${__P(password,)}</stringProp>
          </elementProp>
          <elementProp name="ORG_ID" elementType="Argument">
            <stringProp name="Argument.name">ORG_ID</stringProp>
            <stringProp name="Argument.value">${__P(org_id,50001)}</stringProp>
          </elementProp>
          <elementProp name="SITE_ID" elementType="Argument">
            <stringProp name="Argument.name">SITE_ID</stringProp>
            <stringProp name="Argument.value">${__P(site_id,site001)}</stringProp>
          </elementProp>
          <elementProp name="MATERIAL_TYPE" elementType="Argument">
            <stringProp name="Argument.name">MATERIAL_TYPE</stringProp>
            <stringProp name="Argument.value">${__P(material_type,Plastic)}</stringProp>
          </elementProp>
          <elementProp name="ACCREDITATION_YEAR" elementType="Argument">
            <stringProp name="Argument.name">ACCREDITATION_YEAR</stringProp>
            <stringProp name="Argument.value">${__P(accreditation_year,2027)}</stringProp>
          </elementProp>
          <!-- Unique per run: prevents 400 duplicate-email rejection on repeated runs -->
          <elementProp name="AUTHORISER_EMAIL" elementType="Argument">
            <stringProp name="Argument.name">AUTHORISER_EMAIL</stringProp>
            <stringProp name="Argument.value">perf-auth-${__time(yyyyMMddHHmmss)}@test.example</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree>

      <!-- ── HTTP Defaults ── -->
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement"
                         testname="HTTP Request Defaults">
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
        <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
        <stringProp name="HTTPSampler.port">${__P(port,443)}</stringProp>
        <stringProp name="HTTPSampler.protocol">${__P(protocol,https)}</stringProp>
        <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
        <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
      </ConfigTestElement>
      <hashTree/>

      <!-- ── Header Manager ── -->
      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                     testname="HTTP Header Manager">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="Accept" elementType="Header">
            <stringProp name="Header.name">Accept</stringProp>
            <stringProp name="Header.value">text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8</stringProp>
          </elementProp>
          <elementProp name="Accept-Language" elementType="Header">
            <stringProp name="Header.name">Accept-Language</stringProp>
            <stringProp name="Header.value">en-GB,en;q=0.9</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>

      <!-- ── Basic Auth (staging environments) ── -->
      <AuthManager guiclass="AuthPanel" testclass="AuthManager"
                   testname="HTTP Authorization Manager">
        <collectionProp name="AuthManager.auth_list">
          <elementProp name="BasicAuth" elementType="Authorization">
            <stringProp name="Authorization.url">${__P(protocol,https)}://${BASE_URL}</stringProp>
            <stringProp name="Authorization.username">${USERNAME}</stringProp>
            <stringProp name="Authorization.password">${PASSWORD}</stringProp>
            <stringProp name="Authorization.mechanism">BASIC</stringProp>
          </elementProp>
        </collectionProp>
      </AuthManager>
      <hashTree/>

      <!-- ── Cookie Manager ── -->
      <CookieManager guiclass="CookiePanel" testclass="CookieManager"
                     testname="HTTP Cookie Manager">
        <boolProp name="CookieManager.clearEachIteration">true</boolProp>
      </CookieManager>
      <hashTree/>

      <!-- ══════════════════════════════════════════════════════════
           THREAD GROUP  –  1 user, 1 iteration (baseline)
           ══════════════════════════════════════════════════════════ -->
      <ThreadGroup enabled="true" guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="Operator Accreditation Journey">
        <intProp name="ThreadGroup.num_threads">1</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">stopthread</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>

        <!-- ─────────────────────────────────────────────────────
             SECTION 1 – STUB LOGIN
             ───────────────────────────────────────────────────── -->

        <!-- 01 GET stub login page (operator) -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="01 GET stub login (operator)">
          <stringProp name="HTTPSampler.path">/auth/stub/login?type=operator</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <!-- Correlate crumb (hapi-crumb CSRF token – rotates each response) -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract crumb_token">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">crumb_token</stringProp>
            <stringProp name="RegexExtractor.regex">name="crumb"\s+value="([^"]+)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">CRUMB_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_no">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 02 POST stub login – select operator user -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="02 POST stub login (operator)">
          <stringProp name="HTTPSampler.path">/auth/stub/login</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="crumb" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.name">crumb</stringProp>
                <stringProp name="Argument.value">${crumb_token}</stringProp>
              </elementProp>
              <elementProp name="type" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">type</stringProp>
                <stringProp name="Argument.value">operator</stringProp>
              </elementProp>
              <elementProp name="userId" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">userId</stringProp>
                <stringProp name="Argument.value">stub-op-1</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- ─────────────────────────────────────────────────────
             SECTION 2 – ACCREDITATION LANDING & TASK LIST
             Seeds or fetches the application; stores applicationId in session.
             ───────────────────────────────────────────────────── -->

        <!-- 03 GET operator-accreditation landing -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="03 GET operator-accreditation landing">
          <stringProp name="HTTPSampler.path">/operator-accreditation/${ORG_ID}/${SITE_ID}/${MATERIAL_TYPE}/${ACCREDITATION_YEAR}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <!-- Extract applicationId from task-list link rendered on the landing page -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract applicationId">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">applicationId</stringProp>
            <stringProp name="RegexExtractor.regex">/accreditation/task-list/([^"&lt;\s]+)</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">APP_ID_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_no">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 04 GET task list -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="04 GET task list">
          <stringProp name="HTTPSampler.path">/accreditation/task-list/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- ─────────────────────────────────────────────────────
             SECTION 3 – PRNs (TONNAGE + AUTHORITY)
             Route: /accreditation/tonnage/{applicationId}
                    /accreditation/tonnage-authority/{applicationId}
             No CYA step in current app version.
             ───────────────────────────────────────────────────── -->

        <!-- 05 GET tonnage -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="05 GET tonnage">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract crumb_token">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">crumb_token</stringProp>
            <stringProp name="RegexExtractor.regex">name="crumb"\s+value="([^"]+)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">CRUMB_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_no">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 06 POST tonnage – select planned tonnage band -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="06 POST tonnage (UpTo500)">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="crumb" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.name">crumb</stringProp>
                <stringProp name="Argument.value">${crumb_token}</stringProp>
              </elementProp>
              <elementProp name="plannedTonnageBand" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">plannedTonnageBand</stringProp>
                <stringProp name="Argument.value">UpTo500</stringProp>
              </elementProp>
              <elementProp name="submitAction" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">submitAction</stringProp>
                <stringProp name="Argument.value">saveAndContinue</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- 07 GET tonnage-authority (1st visit – add authoriser) -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="07 GET tonnage-authority">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage-authority/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract crumb_token">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">crumb_token</stringProp>
            <stringProp name="RegexExtractor.regex">name="crumb"\s+value="([^"]+)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">CRUMB_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_no">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 08 POST tonnage-authority – add a new authoriser -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="08 POST tonnage-authority (add authoriser)">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage-authority/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="crumb" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.name">crumb</stringProp>
                <stringProp name="Argument.value">${crumb_token}</stringProp>
              </elementProp>
              <elementProp name="newFullName" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">newFullName</stringProp>
                <stringProp name="Argument.value">Perf Test Authoriser</stringProp>
              </elementProp>
              <elementProp name="newEmail" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">newEmail</stringProp>
                <stringProp name="Argument.value">${AUTHORISER_EMAIL}</stringProp>
              </elementProp>
              <elementProp name="submitAction" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">submitAction</stringProp>
                <stringProp name="Argument.value">addAuthoriser</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- 09 GET tonnage-authority (2nd visit – select the added authoriser) -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="09 GET tonnage-authority (select authoriser)">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage-authority/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract crumb_token">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">crumb_token</stringProp>
            <stringProp name="RegexExtractor.regex">name="crumb"\s+value="([^"]+)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">CRUMB_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_no">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 10 POST tonnage-authority – select authoriser and continue -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="10 POST tonnage-authority (select and continue)">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage-authority/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="crumb" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.name">crumb</stringProp>
                <stringProp name="Argument.value">${crumb_token}</stringProp>
              </elementProp>
              <elementProp name="selectedEmails" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">selectedEmails</stringProp>
                <stringProp name="Argument.value">${AUTHORISER_EMAIL}</stringProp>
              </elementProp>
              <elementProp name="submitAction" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">submitAction</stringProp>
                <stringProp name="Argument.value">saveAndContinue</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- 11 GET tonnage-cya (controller redirects here after saveAndContinue on tonnage-authority) -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="11 GET tonnage-cya">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage-cya/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract crumb_token">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">crumb_token</stringProp>
            <stringProp name="RegexExtractor.regex">name="crumb"\s+value="([^"]+)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">CRUMB_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_no">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 12 POST tonnage-cya – confirm PRNs section -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="12 POST tonnage-cya (confirm)">
          <stringProp name="HTTPSampler.path">/accreditation/tonnage-cya/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="crumb" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.name">crumb</stringProp>
                <stringProp name="Argument.value">${crumb_token}</stringProp>
              </elementProp>
              <elementProp name="submitAction" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">submitAction</stringProp>
                <stringProp name="Argument.value">confirm</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- ─────────────────────────────────────────────────────
             SECTION 4 – BUSINESS PLAN
             Route: /accreditation/business-plan/{applicationId}
                    /accreditation/business-plan-detail/{applicationId}
                    /accreditation/business-plan-cya/{applicationId}
             Percentages must sum to exactly 100.
             ───────────────────────────────────────────────────── -->

        <!-- 11 GET business-plan -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="11 GET business-plan">
          <stringProp name="HTTPSampler.path">/accreditation/business-plan/${applicationId}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="200">200</stringProp>
            </collectionProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
          </ResponseAssertion>
          <hashTree/>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract crumb_token">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
